# =============================================================================
# BMP-Backend — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# All values here are placeholders — no real credentials should appear here.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# The URL of the frontend app — used to construct tracking links sent via SMS.
# In production: FRONTEND_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins for CORS.
# In production, set this to your actual frontend URL(s) only.
# Do NOT include localhost in production.
# Example: ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Internal secret for the /api/db-health endpoint (production only).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=your_internal_secret_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 64 characters in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_64_chars

# ── Default Admin Account ─────────────────────────────────────────────────────
# Set these to create the initial admin account on first startup.
# Leave blank to skip admin creation (you can create it manually later).
# IMPORTANT: Change these immediately after first login.
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=YourStrongPassword123!
DEFAULT_ADMIN_PHONE=9999999999

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSL=false

# Optional: full connection URL (overrides individual DB_* vars if set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for BullMQ notification queue, token blacklisting, and caching.
# Leave blank to disable Redis features (not recommended for production).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
# REDIS_URL=redis://:password@localhost:6379

# ── Google Maps Platform ──────────────────────────────────────────────────────
# Create API keys at: https://console.cloud.google.com/apis/credentials
# Restrict each key to only the APIs it needs and to your server's IP.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_ADDRESS_VALIDATION_API_KEY=your_google_address_validation_key_here
GOOGLE_ROUTES_API=your_google_routes_api_key_here
GOOGLE_DISTANCE_MATRIX_API=your_google_distance_matrix_api_key_here
GOOGLE_GEOCODING_API=your_google_geocoding_api_key_here
GOOGLE_GEOLOCATION_KEY=your_google_geolocation_key_here

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── Twilio (OTP SMS + WhatsApp) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
# Set to 'true' to send real SMS. 'false' logs only (safe for dev).
TWILIO_SMS_ENABLED=false
# Trial mode: redirects all SMS to TEST_PHONE_NUMBER (Twilio free trial restriction).
# Set to 'false' in production with a paid account.
TWILIO_TRIAL_MODE=true
TWILIO_WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OTP Configuration ─────────────────────────────────────────────────────────
# IMPORTANT: Keep these in sync with OTP_CONFIG in BMP-FE/src/core/constants/app.constant.jsx
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=10
OTP_LOCKOUT_MINUTES=15

# ── Firebase (FCM Push Notifications) ────────────────────────────────────────
# Paste the entire service account JSON as a single-line string.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=Book My Parcel

# ── Test / Seed Data ──────────────────────────────────────────────────────────
# Phone number used by the seed script and Twilio trial mode redirect
TEST_PHONE_NUMBER=9999999999
