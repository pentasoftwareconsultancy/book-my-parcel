# =============================================================================
# BMP-Backend — PRODUCTION Environment Variables
# Monorepo: pentasoftwareconsultancy/book-my-parcel
# Server: Hostinger KVM 4 — Arch Linux — Mumbai
#
# Copy to .env on the VPS:
#   cp BMP-Backend/.env.production.example BMP-Backend/.env
#   vim BMP-Backend/.env   (fill in all values)
#   chmod 600 BMP-Backend/.env
#
# NEVER commit this file with real values.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=https://api.yourdomain.com          # ← replace with your API domain
FRONTEND_URL=https://yourdomain.com          # ← replace with your frontend domain

# Frontend origins allowed for CORS — no localhost in production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Internal secret for /api/db-health endpoint
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=REPLACE_WITH_32_CHAR_HEX

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Default Admin Account ─────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_8_CHARS
DEFAULT_ADMIN_PHONE=REPLACE_WITH_PHONE_NUMBER

# ── Database (PostgreSQL — local on VPS) ──────────────────────────────────────
# Use the credentials generated by vps-setup.sh
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bmp_production
DB_USER=bmp_db_user
DB_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
DB_SSL=false

# ── Redis (local on VPS) ──────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=   # leave blank if no auth (localhost-only is safe)

# ── Google Maps Platform ──────────────────────────────────────────────────────
# Restrict each key to your VPS IP in Google Cloud Console
GOOGLE_API_KEY=REPLACE_WITH_ROTATED_KEY
GOOGLE_ADDRESS_VALIDATION_API_KEY=REPLACE_WITH_ROTATED_KEY
GOOGLE_ROUTES_API=REPLACE_WITH_ROTATED_KEY
GOOGLE_DISTANCE_MATRIX_API=REPLACE_WITH_ROTATED_KEY
GOOGLE_GEOCODING_API=REPLACE_WITH_ROTATED_KEY
GOOGLE_GEOLOCATION_KEY=REPLACE_WITH_ROTATED_KEY

# ── Payment Gateway (Razorpay LIVE keys) ─────────────────────────────────────
# Switch from rzp_test_* to rzp_live_* for production
RAZORPAY_KEY_ID=rzp_live_REPLACE
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_LIVE_SECRET

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_ROTATED_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_ROTATED_TOKEN
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
TWILIO_SMS_ENABLED=true
TWILIO_TRIAL_MODE=false
TWILIO_WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_FROM=whatsapp:+91XXXXXXXXXX

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=10
OTP_LOCKOUT_MINUTES=15

# ── Firebase (FCM Push Notifications) ────────────────────────────────────────
# Paste the entire service account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
SMTP_FROM_NAME=Book My Parcel
