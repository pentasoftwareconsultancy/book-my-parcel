# =============================================================================
# BMP-FE — PRODUCTION Environment Variables
# Backend: Hostinger VPS KVM 4 (Arch Linux, Mumbai)
#
# These are set as GitHub Actions secrets — NOT committed to the repo.
# Secret names used in the workflows:
#   VITE_API_URL_PRODUCTION
#   VITE_WS_URL_PRODUCTION
#   VITE_BASE_URL_PRODUCTION
#   VITE_GEOAPIFY_KEY
# =============================================================================

# Backend API — your VPS domain (must have SSL)
VITE_API_URL=https://api.yourdomain.com/api
VITE_REACT_APP_API_URL=https://api.yourdomain.com/api

# WebSocket — same domain, NO /api suffix
VITE_WS_URL=https://api.yourdomain.com

# Base URL (used for asset/upload URLs)
VITE_BASE_URL=https://api.yourdomain.com

# Geoapify map key (safe to expose — restrict to your domain in Geoapify dashboard)
VITE_GEOAPIFY_KEY=your_geoapify_key_here

# Google Maps keys are served from the backend — do NOT add them here
