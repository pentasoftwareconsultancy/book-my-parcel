# =============================================================================
# BMP-FE — Local Development Environment
# =============================================================================
# Copy this file to .env and fill in your actual values.
# This file is in .gitignore — NEVER commit .env with real values.
# =============================================================================

# ── API & WebSocket URLs ──────────────────────────────────────────────────────
# Single source of truth — VITE_API_URL is used everywhere.
# VITE_REACT_APP_API_URL is a legacy alias kept for backward compatibility.
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000
VITE_REACT_APP_API_URL=http://localhost:3000/api
VITE_BASE_URL=http://localhost:3000

# ── Google Maps Platform ──────────────────────────────────────────────────────
# Get keys from: https://console.cloud.google.com/apis/credentials
# For development, restrict keys to localhost in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GOOGLE_MAPS_JAVASCRIPT_API=your_google_maps_javascript_key_here
VITE_GOOGLE_PLACES_API=your_google_places_api_key_here
VITE_GOOGLE_GEOCODING_API=your_google_geocoding_key_here
VITE_GOOGLE_ROUTES_API=your_google_routes_api_key_here
VITE_GOOGLE_DIRECTION_API=your_google_direction_api_key_here
VITE_GOOGLE_DISTANCE_MATRIX_API=your_google_distance_matrix_key_here
VITE_GOOGLE_GEOLOCATION_KEY=your_google_geolocation_key_here
VITE_GOOGLE_MAPS_EMBED_API=your_google_maps_embed_key_here

# ── Geoapify ──────────────────────────────────────────────────────────────────
VITE_GEOAPIFY_KEY=your_geoapify_key_here
