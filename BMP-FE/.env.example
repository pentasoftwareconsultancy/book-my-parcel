# =============================================================================
# BMP-FE — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# All VITE_* variables are bundled into the client — do NOT put secrets here.
# For Google Maps keys, restrict them in Google Cloud Console to your domain.
# =============================================================================

# ── API URLs ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000
VITE_BASE_URL=http://localhost:3000
VITE_REACT_APP_API_URL=http://localhost:3000/api

# ── Geoapify (alternative map provider) ──────────────────────────────────────
# Get key from: https://www.geoapify.com/
VITE_GEOAPIFY_KEY=your_geoapify_key_here

# ── Google Maps Platform ──────────────────────────────────────────────────────
# Google API keys are now served securely from the backend via /api/places/maps-key
# Do NOT add any VITE_GOOGLE_* keys here — they would be exposed in the browser bundle.
